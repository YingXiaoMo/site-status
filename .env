# API URL - 必填
## 由于官方网站可能存在 CORS 问题，您可以使用反向代理来解决此问题（请自行设置）。
## 更多详情，请参阅项目 README.md。

API_URL="https://api.uptimerobot.com/v2/"

# UptimeRobot API 密钥 - 必填
## 本项目仅需要只读 API 密钥
## https://dashboard.uptimerobot.com/integrations

API_KEY="ur2910830-1abc762f0a4855eace9e9e50"

# 部署平台 - 必填
## cloudflare（默认）|auto
## 如果您使用cloudflare以外的平台，请改为auto
DEPLOYMENT_PLATFORM="auto"

# 网站标题
SITE_TITLE="天天站点监测"

# 站点描述
SITE_DESCRIPTION="一个简约的站点监测 | a simple site-status pages, power by uptimerobot"

# 网站关键词
SITE_KEYWORDS="站点监测,监测,监控"

# 网站标志
SITE_LOGO="/favicon.ico"

# ICP备案
## In China, you need to provide an ICP (Internet Content Provider) filing number.
## https://beian.miit.gov.cn/
SITE_ICP=""

# 统计天数
## 统计天数
## 建议填写 30 - 90
COUNT_DAYS=60

# 显示链接
## 是否显示网站链接
SHOW_LINKS=true

# 密码
## 如需保护数据，可设置密码
SITE_PASSWORD=""
## 用于 JWT 验证的密钥，必填
SITE_SECRE_KEY="site-status"
